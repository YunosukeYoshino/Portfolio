{
  "name": "portfolio-tanstack",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless portfolio vite",
    "build": "vite build",
    "start": "vite preview",
    "preview": "vite build && vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "bun run lint:biome && bun run lint:tsc && bun run lint:markup",
    "lint:biome": "biome check .",
    "lint:tsc": "tsc --noEmit",
    "lint:markup": "markuplint 'src/**/*.{jsx,tsx}'",
    "fix": "bun run fix:biome && bun run format",
    "fix:biome": "biome check --fix .",
    "format": "biome format --write .",
    "check": "biome check .",
    "ci": "biome ci .",
    "deploy": "bun run build && wrangler deploy",
    "deploy:preview": "bun run build && wrangler deploy --env preview",
    "wrangler": "wrangler",
    "cf:typegen": "wrangler types",
    "seo:optimize": "bun run scripts/seo-optimize.ts",
    "seo:optimize:force": "bun run scripts/seo-optimize.ts --force",
    "seo:optimize:dry": "bun run scripts/seo-optimize.ts --dry-run",
    "verify:deployment": "bun run scripts/verify-deployment-assets.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-router": "^1.170.8",
    "@tanstack/react-start": "^1.168.12",
    "@vitejs/plugin-react": "^6.0.2",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.16.0",
    "marked": "^18.0.4",
    "postcss-preset-env": "^11.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "shiki": "^4.1.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cloudflare/vite-plugin": "^1.38.0",
    "@markuplint/jsx-parser": "^4.18.3",
    "@markuplint/react-spec": "^4.18.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/jsdom": "21.1.7",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "autoprefixer": "^10.5.0",
    "husky": "^9.1.7",
    "jsdom": "26.0.0",
    "lint-staged": "^17.0.5",
    "markuplint": "^4.18.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7",
    "wrangler": "^4.94.0"
  },
  "overrides": {
    "undici": ">=7.24.0",
    "uuid": ">=14.0.0",
    "yaml": ">=2.8.3",
    "picomatch": ">=2.3.2",
    "diff": ">=8.0.3",
    "mdast-util-to-hast": ">=13.2.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "biome check --write --unsafe",
      "markuplint"
    ],
    "src/**/*.{json,css,scss}": [
      "biome format --write"
    ]
  },
  "trustedDependencies": []
}
