{
  "name": "portfolio-tanstack",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless portfolio vite",
    "build": "vite build",
    "start": "vite preview",
    "preview": "vite build && vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "run-p lint:*",
    "lint:biome": "biome check .",
    "lint:tsc": "tsc --noEmit",
    "lint:markup": "markuplint 'src/**/*.{jsx,tsx}'",
    "fix": "run-p fix:*",
    "fix:biome": "biome check --fix .",
    "format": "biome format --write .",
    "check": "biome check .",
    "ci": "biome ci .",
    "deploy": "bun run build && npx wrangler pages deploy dist/client --project-name=yunosuke-portfolio --branch=main --commit-dirty=true",
    "deploy:preview": "bun run build && npx wrangler pages deploy dist/client --project-name=yunosuke-portfolio --branch=preview --commit-dirty=true",
    "wrangler": "wrangler",
    "seo:optimize": "bun run scripts/seo-optimize.ts",
    "seo:optimize:force": "bun run scripts/seo-optimize.ts --force",
    "seo:optimize:dry": "bun run scripts/seo-optimize.ts --dry-run",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.166.3",
    "@tanstack/react-start": "^1.166.3",
    "@vitejs/plugin-react": "^5.1.4",
    "beautiful-mermaid": "^1.1.3",
    "clsx": "^2.1.1",
    "gsap": "^3.14.2",
    "lenis": "^1.3.18",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.4",
    "postcss-preset-env": "^11.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "shiki": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@markuplint/jsx-parser": "^4.7.23",
    "@markuplint/react-spec": "^4.5.23",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/three": "^0.183.1",
    "autoprefixer": "^10.4.27",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "markuplint": "^4.14.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.71.0"
  },
  "overrides": {
    "undici": ">=7.18.2",
    "mdast-util-to-hast": ">=13.2.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "biome check --write --unsafe",
      "markuplint"
    ],
    "src/**/*.{json,css,scss}": [
      "biome format --write"
    ]
  }
}
